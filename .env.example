# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored.

# --- OpenAI (server-side only) -----------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Firebase Web SDK (safe to ship to the browser) --------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin SDK (NEVER commit) ---------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Optional — distributed rate limiting for /api/ai/* (recommended in production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional — Firebase App Check (reCAPTCHA v3 site key)
# NEXT_PUBLIC_FIREBASE_APP_CHECK_KEY=

# Set to "false" to allow AI without verified email (not recommended)
# REQUIRE_EMAIL_VERIFICATION=false

# --- Polar (billing — öncelikli) ---------------------------------------------
# POLAR_ACCESS_TOKEN=
# POLAR_PRODUCT_ID=
# POLAR_WEBHOOK_SECRET=
# POLAR_SANDBOX=true
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Gumroad (billing — opsiyonel) -------------------------------------------
# Ürün sayfası: https://gumroad.com/l/xxxx veya https://senin.gumroad.com/l/pro
NEXT_PUBLIC_GUMROAD_PRODUCT_URL=
# Gumroad → ürün → URL'deki id veya Sales'teki product_id
GUMROAD_PRODUCT_ID=
# Yerel test satın alımında ping işlensin: true
# GUMROAD_ALLOW_TEST=true

# --- Gumroad (billing — öncelikli) -------------------------------------------
# Ürün paylaşım linki (gumroad.com/l/... veya gum.co/...)
# GUMROAD_PRODUCT_URL=https://yourname.gumroad.com/l/procv-pro
# Ürün ID (webhook doğrulama, Gumroad ürün ayarından)
# GUMROAD_PRODUCT_ID=

# --- Lemon Squeezy (billing — opsiyonel) -------------------------------------
# See docs/LEMON-SQUEEZY.md for store setup and webhook URL.
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_VARIANT_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# Fallback checkout link (if API keys not set yet):
# NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/...
# Public app URL for redirects (production):
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
